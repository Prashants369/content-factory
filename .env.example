# Factory Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values

# === AI/LLM Providers ===
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OPENROUTER_API_KEY=your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here

# === Image Generation ===
COMFYUI_URL=http://127.0.0.1:8188

# === Backend Services ===
AGENT_ENGINE_URL=http://127.0.0.1:8787
N8N_WEBHOOK_URL=http://localhost:5678
N8N_WEBHOOK_IDEAS_URL=http://localhost:5678/webhook/generate-ideas
OPENCLAW_URL=http://127.0.0.1:18789

# === Database & Cache ===
REDIS_URL=redis://localhost:6379/0

# === API Security ===
INTERNAL_API_KEY=your_internal_api_key_here

# === Social Media (for posting agents) ===
META_USER_ACCESS_TOKEN=your_meta_token_here

# === Client-side (Next.js public) ===
NEXT_PUBLIC_OLLAMA_URL=http://127.0.0.1:11434
NEXT_PUBLIC_COMFYUI_URL=http://127.0.0.1:8188
NEXT_PUBLIC_AGENT_ENGINE_URL=http://127.0.0.1:8787
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678/webhook/generate-ideas
NEXT_PUBLIC_N8N_URL=http://localhost:5678
NEXT_PUBLIC_AGENT_ENGINE_PORT=8787
